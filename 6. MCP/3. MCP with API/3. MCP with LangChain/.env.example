######################
# Elasticsearch
######################
ELASTICSEARCH_URL=http://localhost:9200
ELASTIC_USER=elastic
ELASTIC_PASSWORD=changeme123!

######################
# LLM API Key
######################
OPENAI_API_KEY=""

######################
# MCP (상시 서버: SSE 또는 Streamable HTTP)
# 1) 터미널 A: python mcp_servers.py --sse
#    또는: python mcp_servers.py --streamable-http
# 2) 에이전트: python agent_with_mcp.py "질문"
######################
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8766
# 클라이언트 전송: sse(기본) | streamable-http
MCP_CLIENT_TRANSPORT=sse
# 경로(서버/클라이언트 동일하게 맞출 것; 비우면 FastMCP 기본값)
# MCP_SSE_PATH=/sse
# MCP_STREAMABLE_HTTP_PATH=/mcp
# 전체 URL로 덮어쓰기 가능
# MCP_SSE_URL=http://127.0.0.1:8766/sse
# MCP_STREAMABLE_HTTP_URL=http://127.0.0.1:8766/mcp
# 예전처럼 subprocess stdio만 쓰려면:
# MCP_USE_STDIO=1

