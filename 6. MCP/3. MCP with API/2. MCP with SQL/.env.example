# PostgreSQL (postgresql/docker-compose.yml 기본값과 맞춤)
DATABASE_URL=postgresql://admin:admin123@localhost:5432/mcp_db

# 파일 도구가 접근할 수 있는 루트(절대 경로). 이 폴더 밖은 거부됩니다.
# 예: Windows — MCP_FS_ROOT=C:/develop/github/course_LLM/6. MCP/3. MCP with API/2. MCP with SQL/mcp_workspace
# 예: macOS/Linux — MCP_FS_ROOT=/home/user/mcp_workspace
MCP_FS_ROOT=


